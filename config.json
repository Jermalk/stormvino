{
    "models_dir":             "/opt/ov_server/models",
    "device":                 "GPU.1",
    "ov_cache_dir":           "/tmp/ov_cache_b60",
    "default_model":          "qwen3-14b-int4-ov",
    "agent_model":            "qwen3-8b-int4-ov",
    "embedding_model":        "multilingual-e5-large-int8",
    "vision_model":           "qwen2.5-vl-7b-int4-ov",
    "model_aliases":          {
        "qwen2.5-coder:14b":      "qwen2.5-coder-14b-int4",
        "qwen3-14b-int4":         "qwen3-14b-int4-ov",
        "claude-haiku-4-5-20251001": "qwen3-8b-int4-ov",
        "claude-haiku-4-5":       "qwen3-8b-int4-ov",
        "claude-sonnet-4-6":      "qwen3-14b-int4-ov",
        "claude-opus-4-7":        "qwen3-14b-int4-ov"
    },
    "routing": {
        "default":   "local",
        "model_map": {
            "claude-opus-4-7": "ovh"
        },
        "backends": {
            "ovh": {
                "type":        "openai_compat",
                "base_url":    "https://oai.endpoints.kepler.ai.cloud.ovh.net/v1",
                "api_key_env": "OVH_API_KEY",
                "model":       "Qwen3-32B"
            }
        }
    },
    "kv_cache_size_gb":       3,
    "max_loaded_models":      2,
    "vram_headroom_gb":       1.5,
    "max_ram_percent":        75.0,
    "max_new_tokens_default": 2048,
    "max_new_tokens_agent":   500,
    "vlm_max_image_turns":    1,
    "vlm_max_image_side_px":  1280,
    "profiles": {
        "speed":    { "max_loaded_models": 2, "kv_cache_size_gb": 3,  "default_model": "qwen3-14b-int4-ov", "agent_model": "qwen3-8b-int4-ov",  "routing_default": "local" },
        "document": { "max_loaded_models": 1, "kv_cache_size_gb": 12, "default_model": "qwen3-14b-int4-ov", "agent_model": "qwen3-14b-int4-ov", "routing_default": "local" },
        "ovh":      { "max_loaded_models": 1, "kv_cache_size_gb": 3,  "default_model": "qwen3-8b-int4-ov",  "agent_model": "qwen3-8b-int4-ov",  "routing_default": "ovh"   }
    }
}
