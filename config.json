{
    "models_dir":             "/opt/ov_server/models",
    "device":                 "AUTO",
    "ov_cache_dir":           "/home/jerzy/.cache/ov_b60",
    "embedding_model":        "multilingual-e5-large-int8",
    "vision_model":           "qwen2.5-vl-7b-int4-ov",
    "model_aliases": {
        "qwen2.5-coder:14b":  "qwen2.5-coder-14b-int4",
        "qwen3-14b-int4":     "qwen3-14b-int4-ov"
    },

    "max_loaded_models":      1,
    "kv_cache_size_gb":       4,
    "vram_headroom_gb":       1.5,
    "max_ram_percent":        75.0,
    "max_new_tokens_default": 2048,
    "vlm_max_image_turns":    1,
    "vlm_max_image_side_px":  1280,
    "enable_prefix_caching":  true,
    "max_num_batched_tokens":  4096,

    "postgres_dsn":   "postgresql://ov_server:ov_server@localhost/ov_metrics",

    "provider_scope": "local",
    "active_profile": "fast",

    "providers": {
        "ovh": {
            "type":            "openai_compat",
            "base_url":        "https://oai.endpoints.kepler.ai.cloud.ovh.net/v1",
            "api_key_env":     "OVH_API_KEY",
            "catalogue_ttl_sec": 300
        }
    },

    "assessor": {
        "model":          "qwen3-14b-int4-ov",
        "kv_cache_size_gb": 2
    },

    "router": {
        "long_context_tokens":   4000,
        "keywords": {
            "web_search": [
                "search for", "find on the web", "look up", "google",
                "browse", "what's the latest", "latest news", "current events",
                "wyszukaj", "znajdź w internecie", "sprawdź w sieci",
                "najnowsze wiadomości", "aktualne informacje", "co słychać"
            ]
        }
    },

    "profiles": {
        "fast": {
            "thinking":         false,
            "max_new_tokens":   512,
            "model_preference": "fastest"
        },
        "precise": {
            "thinking":         true,
            "max_new_tokens":   4096,
            "model_preference": "balanced"
        },
        "laborious": {
            "thinking":         true,
            "max_new_tokens":   16384,
            "model_preference": "best"
        }
    },

    "task_classes": {
        "vision": {
            "description": "Analyzing or describing an image, photo, chart, diagram, or screenshot",
            "signal":      "has_image",
            "examples": [
                "describe this image",
                "what is in this photo",
                "read the text in this picture",
                "what does this chart show",
                "analyze this screenshot",
                "identify objects in the image"
            ],
            "models": [
                { "id": "qwen2.5-vl-7b-int4-ov", "provider": "loc", "tier": "fast" }
            ]
        },
        "web_search": {
            "description": "Search the web, find current events, retrieve live information",
            "signal":      "has_tools",
            "models": [
                { "id": "qwen3-14b-int4-ov",      "provider": "loc", "tier": "fast" },
                { "id": "Qwen3-32B",               "provider": "ovh", "tier": "best" }
            ]
        },
        "document": {
            "description": "Summarise or analyse a long document or pasted text",
            "signal":      "long_context",
            "context_threshold_tokens": 4000,
            "models": [
                { "id": "qwen3-14b-int4-ov",      "provider": "loc", "tier": "fast" },
                { "id": "Qwen3-32B",               "provider": "ovh", "tier": "fast" },
                { "id": "gpt-oss-120b",            "provider": "ovh", "tier": "best" }
            ]
        },
        "code": {
            "description": "Write, debug, explain, or refactor code",
            "models": [
                { "id": "qwen2.5-coder-14b-int4",        "provider": "loc", "tier": "fast" },
                { "id": "Qwen3-Coder-480B-A35B",          "provider": "ovh", "tier": "best" }
            ]
        },
        "general": {
            "description": "General conversation, questions, opinions, advice, everyday topics, and open-ended reasoning",
            "examples": [
                "what should I have for dinner",
                "recommend a book",
                "how do I stay motivated",
                "what is the weather like",
                "tell me a joke",
                "help me plan my weekend",
                "co zjeść na obiad",
                "jakie filmy warto obejrzeć",
                "jak zaplanować wakacje"
            ],
            "models": [
                { "id": "qwen3-14b-int4-ov",        "provider": "loc", "tier": "fast" },
                { "id": "Qwen3-32B",                 "provider": "ovh", "tier": "best" }
            ]
        }
    },

    "routing": {
        "default":   "local",
        "model_map": {},
        "backends": {
            "ovh": {
                "type":        "openai_compat",
                "base_url":    "https://oai.endpoints.kepler.ai.cloud.ovh.net/v1",
                "api_key_env": "OVH_API_KEY",
                "model":       "Qwen3-32B"
            }
        }
    }
}
