# Python cache
__pycache__/
*.py[cod]

# OpenVINO model binaries — large files, not tracked in git
# Model directories live in models/ and are managed separately (see MODELS.md)
models/

# OpenVINO compile cache (ephemeral, machine-specific)
/tmp/ov_cache*/

# environment files
.env
ov_cache/

# personal tool config
.aider.conf.yml
.claude/

# PND session logs (internal debug/test session artifacts)
dev/autotest/*.md
